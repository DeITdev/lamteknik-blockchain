# ── PostgreSQL (user registry — Cahyo thesis §3.2.4) ──────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/file_manager

# ── Hyperledger Besu (DocumentCertificate metadata + access log) ──────────────
BESU_RPC_URL=http://127.0.0.1:8545
BESU_CHAIN_ID=1337
# Filled in after running `npm run deploy:contract`
DOCUMENT_CERTIFICATE_ADDRESS=
DOCUMENT_CERTIFICATE_BLOCK=0

# Dev signer that signs every transaction (replace with EthSigner/Vault in prod).
# Example below is the well-known Besu dev account — DO NOT use in production.
SERVER_PRIVATE_KEY=0x8f2a55949038a9610f50fb23b5883af3b4ecb3c3bb792cbcefbd1542c692be63

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-long-random-string

# ── IPFS Cluster (backend/ipfs-cluster-private) ───────────────────────────────
IPFS_API_URL=http://127.0.0.1:9095
IPFS_CLUSTER_REST_URL=http://127.0.0.1:9094
IPFS_GATEWAY_URL=http://127.0.0.1:8080
# Public gateway used by the browser to view/download files (client-side).
NEXT_PUBLIC_IPFS_GATEWAY_URL=http://127.0.0.1:8080
