        },
        {
          "name": "POST /lamteknik/{{entity}} (store)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recordId\": \"{{recordId}}\",\n  \"createdTimestamp\": {{createdTimestamp}},\n  \"modifiedTimestamp\": {{modifiedTimestamp}},\n  \"modifiedBy\": \"{{modifiedBy}}\",\n  \"allData\": {{allDataJson}},\n  \"privateKey\": \"{{privateKey}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/lamteknik/{{entity}}",
              "host": ["{{baseUrl}}"],
              "path": ["lamteknik", "{{entity}}"]
            },
            "description": "Calls `store<Entity>(recordId, createdTimestamp, modifiedTimestamp, modifiedBy, allData)` on the entity contract.\n\n`allData` should be a JSON STRING (the full row payload, escaped). The default in the env is already an escaped JSON string. If `privateKey` is empty, the collection pre-request script strips it from the body and the server falls back to DEPLOYER_PRIVATE_KEY / DEFAULT_PRIVATE_KEY in API/.env."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status 200', () => pm.response.to.have.status(200));",
                  "const j = pm.response.json();",
                  "pm.test('success', () => pm.expect(j.success).to.eql(true));",
                  "if (j && j.transactionHash) {",
                  "  pm.collectionVariables.set('txHash', j.transactionHash);",
                  "  console.log('Saved txHash =', j.transactionHash);",
                  "}"
                ]
              }
            }
          ]
        }
