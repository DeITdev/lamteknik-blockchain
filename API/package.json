{
  "name": "lamteknik-blockchain-api",
  "version": "1.0.0",
  "description": "LamTeknik blockchain API using Hyperledger Besu",
  "main": "server-lamteknik.js",
  "type": "module",
  "scripts": {
    "start": "node server-lamteknik.js",
    "dev": "nodemon server-lamteknik.js",
    "compile": "hardhat --config ./hardhat.config.js compile",
    "deploy:lamteknik": "hardhat --config ./hardhat.config.js run ./scripts/deploy-lamteknik.js --network besu"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.7",
    "hardhat": "^3.3.0",
    "nodemon": "^3.0.1"
  },
  "overrides": {
    "cookie": "^0.7.0",
    "elliptic": "^6.6.1",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.4",
    "undici": "^6.23.1"
  },
  "engines": {
    "node": ">=22.10.0"
  }
}
