# Kafka
KAFKA_BROKER=127.0.0.1:29092
KAFKA_CONNECT_URL=http://localhost:8083
KAFKA_GROUP_ID=lamteknik-cdc-consumer-group
TOPIC_PREFIX=lamteknik

# Source DB — change CDC_DB_TYPE to switch connector class
CDC_DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=cdc_user
DB_PASSWORD=cdc_pass
DB_NAME=lamteknik
TARGET_TABLES=akreditasi,user,prodi

# Consumer → blockchain API
API_ENDPOINT=http://127.0.0.1:4100
PRIVATE_KEY=

# Consumer → IPFS (for file/binary columns)
IPFS_CLUSTER_REST_URL=http://127.0.0.1:9094
CDC_FILE_COLUMNS=dokumen,attachment,*_blob,*_file

# Record mapping
CDC_PRIMARY_KEY=id
CDC_WRITE_DELETES=false

# Performance tuning
BATCH_SIZE=50
BATCH_TIMEOUT=50
MAX_CONCURRENT_REQUESTS=10
DEDUP_WINDOW_MS=10000
SKIP_BLOCKCHAIN_CHECK=false
